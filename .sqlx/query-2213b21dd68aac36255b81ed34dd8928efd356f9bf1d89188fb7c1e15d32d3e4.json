{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT v.id AS vehicle_id, v.make, v.model, v.plate_number, va.role\n        FROM public.vehicles v\n        JOIN public.vehicle_access va\n            ON va.vehicle_id = v.id\n            AND va.user_id = $1\n            AND va.role != 'owner'\n        ORDER BY v.make, v.model\n        ",
