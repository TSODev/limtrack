  "query": "SELECT v.id, v.make, v.model, v.plate_number, v.year,\n           o.name AS \"org_name?\"\n           FROM public.vehicles v\n           LEFT JOIN public.organizations o ON o.id = v.org_id\n           WHERE v.company_id = $1\n           ORDER BY v.make, v.model",
