{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            fr.id,\n            fr.user_id,\n            fr.company_id,\n            fr.org_id,\n            fr.role,\n            fr.granted_by,\n            fr.granted_at,\n            u.username,\n            u.email,\n            o.name AS org_name\n        FROM public.fleet_roles fr\n        JOIN public.users u ON u.id = fr.user_id\n        LEFT JOIN public.organizations o ON o.id = fr.org_id\n        WHERE fr.company_id = $1\n        ORDER BY fr.granted_at ASC\n        ",
