{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            v.id,\n            v.owner_id,\n            v.make,\n            v.model,\n            v.plate_number,\n            v.year,\n            v.vin,\n            v.created_at,\n            v.company_id,\n            v.org_id,\n            o.name AS org_name\n        FROM public.vehicles v\n        LEFT JOIN public.organizations o ON o.id = v.org_id\n        WHERE v.company_id = $1\n        ORDER BY o.name NULLS LAST, v.make, v.model\n        ",
