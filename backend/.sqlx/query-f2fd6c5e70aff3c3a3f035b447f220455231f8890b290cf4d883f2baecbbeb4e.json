  "query": "\n        UPDATE public.vehicles SET\n            make         = COALESCE($1, make),\n            model        = COALESCE($2, model),\n            plate_number = COALESCE($3, plate_number),\n            year         = COALESCE($4, year),\n            vin          = COALESCE($5, vin)\n        WHERE id = $6\n        RETURNING\n            id,\n            owner_id,\n            make,\n            model,\n            plate_number,\n            year,\n            vin,\n            created_at,\n            archived_at,\n            $7 AS role\n        ",
